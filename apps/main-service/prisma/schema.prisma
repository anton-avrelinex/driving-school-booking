generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

enum EnrollmentStatus {
  ACTIVE
  COMPLETED
}

model School {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config SchoolConfig?
  users  User[]

  categories  Category[]
  courses     Course[]
  vehicles    Vehicle[]
  enrollments Enrollment[]

  @@map("schools")
}

model SchoolConfig {
  id       String @id @default(uuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id], onDelete: Cascade)

  cancelDeadlineDaysBefore Int     @default(1)
  cancelDeadlineTime       String  @default("15:00")
  lateCancelPenaltyPerHour Decimal @default(0)
  defaultLessonDurationMin Int     @default(120)
  inviteExpiryHours        Int     @default(24)
  defaultReminderHours     Int     @default(24)
  timezone                 String  @default("Europe/Amsterdam")

  @@map("school_configs")
}

model User {
  id                 String   @id @default(uuid())
  schoolId           String
  school             School   @relation(fields: [schoolId], references: [id])

  email              String
  passwordHash       String
  firstName          String
  lastName           String
  role               Role
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean  @default(true)
  reminderHours      Int?
  instructorProfile  InstructorProfile?
  studentProfile     StudentProfile?
  adminProfile       AdminProfile?
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([schoolId, email])
  @@index([schoolId, role])
  @@map("users")
}

model InstructorProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  courses      Course[]
  vehicles     Vehicle[]
  availability InstructorAvailability[]

  @@map("instructor_profiles")
}

model InstructorAvailability {
  id           String            @id @default(uuid())
  instructorId String
  instructor   InstructorProfile @relation(fields: [instructorId], references: [id], onDelete: Cascade)
  dayOfWeek    Int
  startTime    String
  endTime      String

  @@index([instructorId])
  @@map("instructor_availabilities")
}

model StudentProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  enrollments Enrollment[]

  @@map("student_profiles")
}

model AdminProfile {
  id     String @id @default(uuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("admin_profiles")
}

model Enrollment {
  id               String           @id @default(uuid())
  schoolId         String
  school           School           @relation(fields: [schoolId], references: [id])
  studentProfileId String
  studentProfile   StudentProfile   @relation(fields: [studentProfileId], references: [id])
  courseId          String
  course           Course           @relation(fields: [courseId], references: [id])
  hoursPurchased   Decimal
  hoursCompleted   Decimal          @default(0)
  status           EnrollmentStatus @default(ACTIVE)
  createdAt        DateTime         @default(now())

  @@unique([studentProfileId, courseId])
  @@index([schoolId])
  @@map("enrollments")
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  schools  School[]
  courses  Course[]
  vehicles Vehicle[]

  @@map("categories")
}

model Course {
  id           String       @id @default(uuid())
  schoolId     String
  school       School       @relation(fields: [schoolId], references: [id])

  name         String
  price        Decimal
  hours        Int
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id])
  transmission Transmission
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  instructors  InstructorProfile[]
  enrollments  Enrollment[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([categoryId])
  @@map("courses")
}

model Vehicle {
  id           String       @id @default(uuid())
  schoolId     String
  school       School       @relation(fields: [schoolId], references: [id])

  make         String
  model        String
  licensePlate String
  transmission Transmission
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  instructors  InstructorProfile[]

  @@unique([schoolId, licensePlate])
  @@index([schoolId])
  @@index([categoryId])
  @@map("vehicles")
}
