generator client {
  provider     = "prisma-client"
  output       = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum Transmission {
  AUTOMATIC
  MANUAL
}

model School {
  id        String   @id @default(uuid())
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  config SchoolConfig?
  users  User[]

  categories Category[]
  courses    Course[]
  vehicles   Vehicle[]

  @@map("schools")
}

model SchoolConfig {
  id       String @id @default(uuid())
  schoolId String @unique
  school   School @relation(fields: [schoolId], references: [id])

  cancelDeadlineDaysBefore Int     @default(1)
  cancelDeadlineTime       String  @default("15:00")
  lateCancelPenaltyPerHour Decimal @default(0)
  defaultLessonDurationMin Int     @default(120)
  inviteExpiryHours        Int     @default(24)
  defaultReminderHours     Int     @default(24)
  timezone                 String  @default("Europe/Amsterdam")

  @@map("school_configs")
}

model User {
  id                 String   @id @default(uuid())
  schoolId           String
  school             School   @relation(fields: [schoolId], references: [id])

  email              String
  passwordHash       String
  firstName          String
  lastName           String
  role               Role
  status             UserStatus @default(ACTIVE)
  mustChangePassword Boolean  @default(true)
  reminderHours      Int?
  courses            Course[]
  vehicles           Vehicle[]
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([schoolId, email])
  @@index([schoolId, role])
  @@map("users")
}

model Category {
  id   String @id @default(uuid())
  name String @unique

  schools  School[]
  courses  Course[]
  vehicles Vehicle[]

  @@map("categories")
}

model Course {
  id           String       @id @default(uuid())
  schoolId     String
  school       School       @relation(fields: [schoolId], references: [id])

  name         String
  price        Decimal
  hours        Int
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id])
  transmission Transmission
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  instructors  User[]

  @@unique([schoolId, name])
  @@index([schoolId])
  @@index([categoryId])
  @@map("courses")
}

model Vehicle {
  id           String       @id @default(uuid())
  schoolId     String
  school       School       @relation(fields: [schoolId], references: [id])

  make         String
  model        String
  licensePlate String
  transmission Transmission
  categoryId   String
  category     Category     @relation(fields: [categoryId], references: [id])
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  instructors  User[]

  @@unique([schoolId, licensePlate])
  @@index([schoolId])
  @@index([categoryId])
  @@map("vehicles")
}
